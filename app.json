{
  "expo": {
    "name": "cd-app",
    "slug": "cd-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sca.png",
    "scheme": "cdapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/sca.png",
        "backgroundImage": "./assets/images/sca.png",
        "monochromeImage": "./assets/images/sca.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/sca.png",
      "manifest": {
        "name": "cd-app",
        "short_name": "cd-app",
        "start_url": ".",
        "display": "standalone",
        "icons": [
          {
            "src": "./assets/images/sca.png",
            "sizes": "192x192",
            "type": "image/png"
          }
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/sca.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
